{
  "name": "study-flow-server",
  "version": "1.0.0",
  "description": "Backend API for Study Flow",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "DATABASE_URL=:memory: tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@google/generative-ai": "^0.11.4",
    "better-sqlite3": "^11.1.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.32.1",
    "drizzle-zod": "^0.5.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.12",
    "drizzle-kit": "^0.23.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}